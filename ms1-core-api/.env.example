PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/englishx

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-me
JWT_REFRESH_SECRET=your-refresh-secret-change-me
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# AWS SES (configure in AWS Console → SES → Verified Identities)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_SES_FROM_EMAIL=valuedrocks@gmail.com

# Google OAuth (create at console.cloud.google.com → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://englishx.duckdns.org/api/auth/google/callback

# ms2 Speech Agent URL (internal Docker network)
MS2_BASE_URL=http://ms2-speech-agent:8000

# Frontend URL — Vercel deployment (for CORS and invite email links)
FRONTEND_URL=https://englishx.vercel.app

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=ms1-core-api
OTEL_EXPORTER_OTLP_HEADERS=
