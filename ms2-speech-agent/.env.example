PORT=8000

# Google Gemini API (sign up at aistudio.google.com when ready)
GOOGLE_API_KEY=your-gemini-api-key

# Deepgram STT (sign up at deepgram.com when ready)
DEEPGRAM_API_KEY=your-deepgram-api-key

# ms1 Core API URL
MS1_BASE_URL=http://localhost:3001

# OpenTelemetry — Grafana Cloud OTLP Gateway
# Get these from: Grafana Cloud → My Account → OpenTelemetry
# Endpoint example: https://otlp-gateway-prod-ap-southeast-1.grafana.net
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Auth: base64(instanceID:apiToken)  e.g. "Authorization=Basic dXNlcjpwYXNz"
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=ms2-speech-agent
